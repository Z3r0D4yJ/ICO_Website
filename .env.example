# ===========================================
# ICO Website — Environment Variables
# ===========================================
# Kopieer dit bestand naar .env.local en vul de waarden in.
# NOOIT .env.local committen naar git!

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Mollie (alleen server-side via Supabase Edge Functions) ---
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_REDIRECT_URL=https://ico-detailing.be/shop/bevestiging
MOLLIE_WEBHOOK_URL=https://ico-detailing.be/api/mollie-webhook

# --- WhatsApp Business API (via Edge Functions) ---
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_ACCESS_TOKEN=your-access-token
# Fallback: direct WhatsApp nummer voor click-to-chat
VITE_WHATSAPP_NUMBER=32xxxxxxxxx

# --- E-mail (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@ico-detailing.be

# --- Admin accounts (e-mailadressen die admin toegang krijgen) ---
VITE_ADMIN_EMAIL_1=rico@ico-detailing.be
VITE_ADMIN_EMAIL_2=nico@ico-detailing.be

# --- Site ---
VITE_SITE_URL=https://ico-detailing.be
VITE_SITE_NAME=ICO - Intensive Cleaning Organization
VITE_DEFAULT_LOCALE=nl
